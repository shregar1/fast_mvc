# FastMVC Environment Configuration
# Copy this file to .env and update with your values
# Configuration is validated on startup - see config/validator.py for rules

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application name (optional)
APP_NAME="fastmvc"

# Environment: development, staging, production (default: development)
APP_ENV="development"

# Debug mode: true/false (default: false in production)
APP_DEBUG="true"

# Server host (default: 0.0.0.0)
APP_HOST="0.0.0.0"

# Server port (default: 8000)
APP_PORT="8000"

# Disable config validation: true/false (default: true)
# VALIDATE_CONFIG="true"

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Full database URL (validated on startup)
# Format: postgresql://user:password@host:port/database
# Examples:
#   PostgreSQL: postgresql://postgres:password@localhost:5432/fstmvc
#   MySQL:      mysql://user:password@localhost:3306/fstmvc
#   SQLite:     sqlite:///./app.db (relative path)
#               sqlite:////absolute/path/to/app.db
DATABASE_URL="sqlite:///./app.db"

# Individual connection settings (alternative to DATABASE_URL)
# DATABASE_HOST="localhost"
# DATABASE_PORT="5432"
# DATABASE_NAME="fastmvc"
# DATABASE_USER="postgres"
# DATABASE_PASSWORD="postgres123"
DATABASE_POOL_SIZE="5"
DATABASE_MAX_OVERFLOW="10"

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================

# Full Redis URL
# Format: redis://[:password@]host:port/db
# For SSL: rediss://host:port
REDIS_URL="redis://localhost:6379/0"

# Individual settings (alternative to REDIS_URL)
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_DB="0"

# =============================================================================
# SECURITY SETTINGS (REQUIRED)
# =============================================================================

# JWT Secret Key (REQUIRED - must be at least 32 characters)
# This is used for signing JWT tokens. Change in production!
# Requirements:
#   - Minimum 32 characters
#   - Mix of upper, lower, digits, and special characters
#   - Not a common word like "secret" or "password"
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="your-super-secret-jwt-key-must-be-at-least-32-chars-long"

# JWT Algorithm (default: HS256)
# Options: HS256, HS384, HS512, RS256, RS384, RS512, ES256, ES384, ES512
JWT_ALGORITHM="HS256"

# JWT Token expiration in hours (default: 24)
JWT_EXPIRATION_HOURS="24"

# Bcrypt salt for password hashing (default auto-generated)
BCRYPT_SALT="$2b$12$LQv3c1yqBWVHxkd0LHAkCO"

# =============================================================================
# CORS SETTINGS
# =============================================================================

# Allowed CORS origins (comma-separated)
# Use "*" to allow all (not recommended for production)
# Examples:
#   Development: "http://localhost:3000,http://localhost:8080"
#   Production:  "https://myapp.com,https://www.myapp.com"
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

CORS_ALLOW_CREDENTIALS="true"
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS,PATCH"
CORS_ALLOW_HEADERS="*"

# =============================================================================
# RATE LIMITING
# =============================================================================

RATE_LIMIT_REQUESTS_PER_MINUTE="60"
RATE_LIMIT_REQUESTS_PER_HOUR="1000"
RATE_LIMIT_BURST_LIMIT="10"

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="DEBUG"

# Log format: json, console
LOG_FORMAT="json"

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Auto-reload on code changes (development only)
RELOAD="true"

# Number of worker processes (production only)
# WORKERS="4"
