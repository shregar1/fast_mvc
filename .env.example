# {{PROJECT_NAME}} — copy to `.env`. Validation: `utilities/validator.py`.
# DATABASE_URL / REDIS_URL: leave unset or empty to build from DATABASE_* / REDIS_* (`utilities/database_url.py`, `utilities/redis_url.py`).

# --- Application ---
APP_NAME="{{PROJECT_NAME}}"
APP_VERSION="1.0.1"
APP_ENV="development"
DEBUG="false"
LOG_LEVEL="INFO"
LOG_FORMAT="json"
HOST="0.0.0.0"
PORT="8000"

# --- gRPC ---
GRPC_ENABLED="false"
GRPC_HOST="0.0.0.0"
GRPC_PORT="51051"

# --- Docker ---
# Local DB/Redis overlay: docker-compose.yml + docker-compose.local.yml
# Prod / app-only on shared network: docker-compose.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.local.yml
EDGE_NETWORK_NAME="fastx-edge"
APP_PORT="8000"

# --- JWT ---
JWT_SECRET_KEY="change-me-minimum-32-characters-mixed-case-digits-symbols"
SECRET_KEY="change-me-minimum-32-characters-mixed-case-digits-symbols"
ALGORITHM="HS256"
JWT_AUTH_ENABLED="true"
ACCESS_TOKEN_EXPIRE_MINUTE="1440"
REFRESH_TOKEN_EXPIRE_DAYS="7"
JWT_EXPIRATION_HOURS="24"
BCRYPT_SALT=""

# --- Database ---
DATABASE_URL=""
DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_NAME="{{PROJECT_SLUG}}"
DATABASE_USER="postgres"
DATABASE_PASSWORD="change-me-in-production"
DATABASE_POOL_SIZE="5"
DATABASE_MAX_OVERFLOW="10"

# --- Redis ---
REDIS_URL=""
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# --- CORS / rate limit / docs ---
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
CORS_ALLOW_CREDENTIALS="true"
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,OPTIONS,PATCH"
CORS_ALLOW_HEADERS="*"
RATE_LIMIT_REQUESTS_PER_MINUTE="60"
RATE_LIMIT_REQUESTS_PER_HOUR="1000"
RATE_LIMIT_WINDOW_SECONDS="60"
RATE_LIMIT_BURST_LIMIT="10"
DOCS_USERNAME=""
DOCS_PASSWORD=""

# --- Postman / telemetry (optional) ---
# POSTMAN_OUTPUT_DIR="postman"
# TELEMETRY_ENABLED="false"

# --- Compose infrastructure (host ports for postgres/redis containers; bump if colliding on one VM) ---
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="{{PROJECT_SLUG}}"
POSTGRES_PORT="5432"

# --- Caddy (`docker compose --profile caddy`) ---
CADDY_HTTP_PORT="80"
CADDY_HTTPS_PORT="443"
HTTP3_UDP_PORT="443"

# --- LLM (keys via env only) ---
OPENAI_ENABLED="false"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4.1-mini"
ANTHROPIC_ENABLED="false"
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20240620"
OLLAMA_ENABLED="false"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"
GEMINI_ENABLED="false"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
MOONSHOT_ENABLED="false"
MOONSHOT_API_KEY=""
MOONSHOT_BASE_URL="https://api.moonshot.cn/v1"
MOONSHOT_MODEL="moonshot-v1-8k"
XAI_ENABLED="false"
XAI_API_KEY=""
XAI_BASE_URL="https://api.x.ai/v1"
XAI_MODEL="grok-3-mini-latest"
LITELLM_ENABLED="false"
LITELLM_API_BASE="http://localhost:4000/v1"
LITELLM_API_KEY=""
LITELLM_MODEL=""
MISTRAL_ENABLED="false"
MISTRAL_API_KEY=""
MISTRAL_BASE_URL="https://api.mistral.ai/v1"
MISTRAL_MODEL="mistral-small-latest"
DEEPSEEK_ENABLED="false"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
TOGETHER_ENABLED="false"
TOGETHER_API_KEY=""
TOGETHER_BASE_URL="https://api.together.xyz/v1"
TOGETHER_MODEL="meta-llama/Llama-3-8b-chat-hf"
COHERE_ENABLED="false"
COHERE_API_KEY=""
COHERE_MODEL="command-r-plus"
AZURE_OPENAI_ENABLED="false"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2024-06-01"
AZURE_OPENAI_DEPLOYMENT=""

# --- Push (optional) ---
APNS_ENABLED="false"
FCM_ENABLED="false"

# --- Dev ---
RELOAD="true"
